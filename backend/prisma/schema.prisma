// PassAddis Database Schema
// Event ticketing + Shop with supermarket pickup

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== USERS ==============

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  email         String?   @unique
  name          String?
  passwordHash  String?
  isVerified    Boolean   @default(false)
  emailVerified Boolean   @default(false)
  emailVerificationToken String?
  emailVerificationExpiresAt DateTime?
  role          UserRole  @default(USER)
  country       String?           // Auto-detected or user-set (ISO 3166)
  preferredCurrency String?       // Preferred display currency
  isDiaspora    Boolean   @default(false)
  failedLoginAttempts Int @default(0)
  lockedUntil   DateTime?
  resetToken    String?
  resetTokenExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  tickets       Ticket[]
  orders        Order[]
  organizer     Organizer?
  merchant      Merchant?
  otpCodes      OtpCode[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  notifications Notification[]
  savedEvents   SavedEvent[]
  wallet        UserWallet?
  followedOrganizers OrganizerFollow[]
  referrals     Referral[]          @relation("ReferrerUser")
  eventRatings  EventRating[]
  donations     Donation[]
  loyaltyAccount LoyaltyAccount?
  promoterProfile Promoter?

  @@map("users")
}

enum UserRole {
  USER
  ORGANIZER
  PROMOTER
  SHOP_OWNER
  ADMIN
}

model OtpCode {
  id        String   @id @default(uuid())
  code      String
  phone     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@map("otp_codes")
}

model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  revokedAt   DateTime?
  deviceInfo  String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ============== AUDIT LOG ==============

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entity      String   // User, Event, Order, etc.
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
  userId      String?

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============== PROMO CODES ==============

model PromoCode {
  id            String       @id @default(uuid())
  code          String       @unique
  description   String?
  discountType  DiscountType
  discountValue Float        // Percentage or fixed amount
  minPurchase   Float?       // Minimum purchase amount
  maxDiscount   Float?       // Maximum discount (for percentage)
  maxUses       Int?         // Total uses allowed (null = unlimited)
  usedCount     Int          @default(0)
  maxUsesPerUser Int         @default(1)
  validFrom     DateTime
  validUntil    DateTime
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Optional: limit to specific event
  eventId       String?
  event         Event?       @relation(fields: [eventId], references: [id])

  usages        PromoCodeUsage[]

  @@index([code])
  @@index([eventId])
  @@map("promo_codes")
}

model PromoCodeUsage {
  id          String    @id @default(uuid())
  usedAt      DateTime  @default(now())
  discount    Float     // Actual discount applied

  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  promoCodeId String
  orderId     String
  userId      String

  @@unique([promoCodeId, orderId])
  @@index([userId])
  @@map("promo_code_usages")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ============== WAITLIST ==============

model Waitlist {
  id          String   @id @default(uuid())
  email       String?
  phone       String?
  ticketTypeId String?
  notified    Boolean  @default(false)
  notifiedAt  DateTime?
  createdAt   DateTime @default(now())

  event       Event    @relation(fields: [eventId], references: [id])
  eventId     String
  userId      String?

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("waitlists")
}

// ============== USER WALLET (Gift Balance) ==============

model UserWallet {
  id        String   @id @default(uuid())
  balance   Float    @default(0)    // Current balance in ETB
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique

  transactions UserWalletTransaction[]

  @@map("user_wallets")
}

model UserWalletTransaction {
  id            String                    @id @default(uuid())
  type          UserWalletTransactionType
  amount        Float                     // Amount in ETB
  currency      String                    @default("ETB")  // Original currency
  originalAmount Float?                   // Amount in original currency
  exchangeRate  Float?                    // Rate used for conversion
  description   String
  reference     String?                   // Order ID, sender user ID, etc.
  senderName    String?                   // Name of person who sent the funds
  createdAt     DateTime                  @default(now())

  wallet        UserWallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  walletId      String

  @@index([walletId, createdAt])
  @@map("user_wallet_transactions")
}

enum UserWalletTransactionType {
  TOP_UP         // Loaded by diaspora user
  GIFT_RECEIVED  // Received from another user
  GIFT_SENT      // Sent to another user
  PURCHASE       // Spent on tickets/shop
  REFUND         // Refunded from order
}

// ============== NOTIFICATIONS ==============

model Notification {
  id        String             @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  data      Json?              // Extra data (eventId, orderId, etc.)
  isRead    Boolean            @default(false)
  readAt    DateTime?
  createdAt DateTime           @default(now())

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  TICKET_PURCHASED
  TICKET_TRANSFERRED
  TICKET_RECEIVED
  ORDER_CONFIRMED
  ORDER_READY
  ORDER_CANCELLED
  REFUND_PROCESSED
  EVENT_REMINDER
  EVENT_CANCELLED
  WAITLIST_AVAILABLE
  PROMO_AVAILABLE
  SYSTEM
}

// ============== SAVED EVENTS ==============

model SavedEvent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@map("saved_events")
}

// ============== MERCHANTS (Sub-merchants under PassAddis) ==============

model Merchant {
  id              String         @id @default(uuid())
  merchantCode    String         @unique  // Sub-merchant ID (e.g., PA001, PA002)
  businessName    String
  tradeName       String?        // Display name
  description     String?
  logo            String?
  type            MerchantType   @default(ORGANIZER)
  status          MerchantStatus @default(PENDING)

  // Business details
  tinNumber       String?        // Tax ID
  licenseNumber   String?
  businessAddress String?
  city            String         @default("Addis Ababa")

  // Settlement info
  bankName        String?
  bankAccount     String?
  telebirrAccount String?        // For Telebirr payouts
  cbeBirrAccount  String?        // For CBE Birr payouts

  // Commission & fees
  commissionRate  Float          @default(5.0)  // PassAddis takes 5%
  settlementDays  Int            @default(3)    // T+3 settlement
  minPayout       Float          @default(100)  // Min 100 ETB to settle

  // Verification
  isVerified      Boolean        @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  user            User           @relation(fields: [userId], references: [id])
  userId          String         @unique
  events          Event[]
  settlements     Settlement[]
  walletTransactions WalletTransaction[]
  shopItems       ShopItem[]
  orders          Order[]        // Shop orders for this merchant

  @@index([status])
  @@index([type])
  @@index([isVerified])
  @@index([status, type])  // Composite for filtering merchants by type and status
  @@map("merchants")
}

enum MerchantType {
  ORGANIZER      // Event organizers
  SHOP           // Shop partners
  SUPERMARKET    // Pickup location partners
  VENDOR         // Other vendors
}

enum MerchantStatus {
  PENDING        // Awaiting verification
  ACTIVE         // Verified and active
  SUSPENDED      // Temporarily suspended
  BLOCKED        // Permanently blocked
}

// ============== MERCHANT WALLET ==============

model WalletTransaction {
  id            String              @id @default(uuid())
  type          WalletTransactionType
  amount        Float
  fee           Float               @default(0)
  netAmount     Float               // amount - fee
  balanceBefore Float
  balanceAfter  Float
  description   String?
  reference     String?             // Order ID or Settlement ID
  status        String?             // Transaction status
  orderId       String?             // Link to order for refunds
  createdAt     DateTime            @default(now())

  merchant      Merchant            @relation(fields: [merchantId], references: [id])
  merchantId    String

  @@map("wallet_transactions")
}

enum WalletTransactionType {
  CREDIT         // Money in (from sales)
  DEBIT          // Money out (settlement)
  FEE            // Platform fee deduction
  REFUND         // Refund to customer
  ADJUSTMENT     // Manual adjustment
}

// ============== SETTLEMENTS ==============

model Settlement {
  id              String           @id @default(uuid())
  settlementRef   String           @unique  // e.g., STL-20241215-001
  amount          Float
  fee             Float            @default(0)
  netAmount       Float
  status          SettlementStatus @default(PENDING)
  method          PaymentMethod
  bankRef         String?          // Bank transfer reference
  processedAt     DateTime?
  failureReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  merchant        Merchant         @relation(fields: [merchantId], references: [id])
  merchantId      String

  @@map("settlements")
}

enum SettlementStatus {
  PENDING        // Awaiting processing
  PROCESSING     // Being processed
  COMPLETED      // Successfully settled
  FAILED         // Settlement failed
}

// ============== ORGANIZERS (Legacy - now Merchant) ==============

model Organizer {
  id            String   @id @default(uuid())
  businessName  String
  description   String?
  logo          String?
  isVerified    Boolean  @default(false)
  bankAccount   String?
  telebirrId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Social / public profile fields
  website       String?
  socialLinks   Json?     // { instagram, twitter, facebook, tiktok }
  bannerImage   String?
  featuredVideoUrl String?

  user          User     @relation(fields: [userId], references: [id])
  userId        String   @unique
  events        Event[]
  followers     OrganizerFollow[]

  @@index([isVerified])
  @@map("organizers")
}

// ============== EVENTS ==============

model Event {
  id              String      @id @default(uuid())
  title           String
  description     String
  imageUrl        String?
  venue           String
  address         String?
  city            String      @default("Addis Ababa")
  date            DateTime
  endDate         DateTime?
  category        EventCategory
  status          EventStatus @default(DRAFT)
  isFeatured      Boolean     @default(false)

  // Media gallery
  imageGallery    Json?       // Array of image URLs
  videoUrl        String?     // YouTube/Vimeo embed URL

  // Fee absorption (organizer pays platform fee)
  absorbsFees     Boolean     @default(false)

  // Donation support
  donationsEnabled Boolean    @default(false)
  donationGoal    Float?      // Target amount (optional)

  // Presale
  presaleEnabled  Boolean     @default(false)
  presaleStartsAt DateTime?
  presaleEndsAt   DateTime?

  // Group tickets
  groupDiscountEnabled Boolean @default(false)
  groupMinSize    Int?        @default(5)
  groupDiscountPercent Float? @default(10)

  // Approval workflow
  submittedAt     DateTime?   // When submitted for approval
  approvedAt      DateTime?   // When approved by admin
  approvedBy      String?     // Admin user ID who approved
  rejectionReason String?     // Reason if rejected

  // Cancellation support
  cancelledAt     DateTime?   // When event was cancelled

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Recurring event support
  isRecurring     Boolean     @default(false)
  recurrenceRule  String?     // RRULE string (e.g., "FREQ=WEEKLY;BYDAY=SA;COUNT=10")
  parentEventId   String?     // Links to parent recurring event
  parentEvent     Event?      @relation("RecurringEvents", fields: [parentEventId], references: [id])
  childEvents     Event[]     @relation("RecurringEvents")

  // Can be linked to either Organizer (legacy) or Merchant (new)
  organizer     Organizer?  @relation(fields: [organizerId], references: [id])
  organizerId   String?
  merchant      Merchant?   @relation(fields: [merchantId], references: [id])
  merchantId    String?

  ticketTypes   TicketType[]
  tickets       Ticket[]
  promoCodes    PromoCode[]
  waitlist      Waitlist[]
  shopItems     ShopItem[]
  savedBy       SavedEvent[]
  sessions      EventSession[]
  messages      EventMessage[]
  referrals     Referral[]
  ratings       EventRating[]
  donations     Donation[]
  resaleListings TicketResale[]
  presaleCodes  PresaleCode[]
  promoters     EventPromoter[]

  @@index([merchantId])
  @@index([organizerId])
  @@index([status])
  @@index([date])
  @@index([category])
  @@index([isFeatured])
  @@index([parentEventId])
  @@index([status, date])  // Composite for published events by date
  @@map("events")
}

enum EventCategory {
  MUSIC
  SPORTS
  ARTS
  COMEDY
  FESTIVAL
  CONFERENCE
  NIGHTLIFE
  OTHER
}

enum EventStatus {
  DRAFT           // Initial state when organizer creates event
  PENDING         // Submitted for admin approval
  APPROVED        // Admin approved, ready to publish
  PUBLISHED       // Live and visible to public
  REJECTED        // Admin rejected
  CANCELLED       // Event cancelled
  COMPLETED       // Event has ended
}

// ============== TICKETS ==============

model TicketType {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float    // Base price (fallback)
  quantity    Int
  sold        Int      @default(0)
  maxPerOrder Int      @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event    @relation(fields: [eventId], references: [id])
  eventId     String
  tickets     Ticket[]
  pricingTiers PricingTier[]

  @@map("ticket_types")
}

// ============== PRICING TIERS (Early Bird, etc.) ==============

model PricingTier {
  id            String   @id @default(uuid())
  name          String   // "Early Bird", "Regular", "Last Minute"
  price         Float

  // Activation rules (one or both)
  startsAt      DateTime?  // When this tier becomes active
  endsAt        DateTime?  // When this tier ends
  maxQuantity   Int?       // First X tickets at this price

  isActive      Boolean  @default(true)
  priority      Int      @default(0)  // Higher = checked first

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ticketType    TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  ticketTypeId  String

  @@index([ticketTypeId])
  @@index([ticketTypeId, isActive])
  @@map("pricing_tiers")
}

model Ticket {
  id          String       @id @default(uuid())
  qrCode      String       @unique
  status      TicketStatus @default(VALID)
  usedAt      DateTime?
  createdAt   DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id])
  userId      String
  event       Event        @relation(fields: [eventId], references: [id])
  eventId     String
  ticketType  TicketType   @relation(fields: [ticketTypeId], references: [id])
  ticketTypeId String
  order       Order?       @relation(fields: [orderId], references: [id])
  orderId     String?
  transfers   TicketTransfer[]
  resale      TicketResale?

  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@index([orderId])
  @@map("tickets")
}

enum TicketStatus {
  VALID
  USED
  CANCELLED
  EXPIRED
  TRANSFERRED  // Original ticket after transfer
}

// ============== TICKET TRANSFERS ==============

model TicketTransfer {
  id              String         @id @default(uuid())
  status          TransferStatus @default(PENDING)
  recipientPhone  String?
  recipientEmail  String?
  message         String?        // Optional message to recipient
  transferCode    String         @unique  // Code recipient uses to claim
  expiresAt       DateTime       // Transfer expires if not claimed
  claimedAt       DateTime?
  createdAt       DateTime       @default(now())

  ticket          Ticket         @relation(fields: [ticketId], references: [id])
  ticketId        String
  fromUserId      String
  toUserId        String?        // Set when claimed

  @@index([transferCode])
  @@index([ticketId])
  @@map("ticket_transfers")
}

enum TransferStatus {
  PENDING    // Waiting for recipient to claim
  CLAIMED    // Successfully transferred
  EXPIRED    // Not claimed in time
  CANCELLED  // Sender cancelled
}

// ============== SHOP ==============

model ShopItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  category    ShopCategory
  inStock     Boolean  @default(true)
  stockQuantity Int    @default(0)         // Actual stock count
  lowStockThreshold Int @default(10)       // Alert when below this
  sku         String?  @unique             // Product SKU

  // Curated/Featured items
  isCurated   Boolean  @default(false)     // Shop owner's curated selection
  isFeatured  Boolean  @default(false)     // Featured on homepage
  displayOrder Int     @default(0)         // Order in curated list
  badge       String?                       // "Best Seller", "New", "Popular"

  // Event-specific items
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id])

  // Shop/Merchant ownership
  merchantId  String?
  merchant    Merchant? @relation(fields: [merchantId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]

  @@index([merchantId])
  @@index([eventId])
  @@index([category])
  @@index([isCurated])
  @@map("shop_items")
}

enum ShopCategory {
  WATER
  DRINKS
  SNACKS
  MERCH
  BUNDLES        // For promotional bundles
}

model PickupLocation {
  id        String   @id @default(uuid())
  name      String
  area      String
  address   String
  hours     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]

  @@map("pickup_locations")
}

// ============== BUNDLES ==============

model Bundle {
  id           String       @id @default(uuid())
  name         String
  description  String?
  originalPrice Float       // Sum of individual prices
  bundlePrice  Float        // Discounted bundle price
  savings      Float        // originalPrice - bundlePrice
  imageUrl     String?
  isActive     Boolean      @default(true)
  isFeatured   Boolean      @default(false)
  validFrom    DateTime?
  validUntil   DateTime?
  maxQuantity  Int?         // Max bundles available
  soldCount    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Optional: limit to specific event
  eventId      String?

  items        BundleItem[]

  @@index([eventId])
  @@index([isActive])
  @@map("bundles")
}

model BundleItem {
  id          String   @id @default(uuid())
  quantity    Int      @default(1)

  bundle      Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  bundleId    String
  shopItemId  String?
  ticketTypeId String?

  @@map("bundle_items")
}

// ============== ORDERS ==============

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  status          OrderStatus   @default(PENDING)
  subtotal        Float
  serviceFee      Float         @default(0)
  platformFee     Float         @default(0)  // PassAddis commission
  total           Float
  merchantAmount  Float?        // Amount to be settled to merchant
  paymentMethod   PaymentMethod?
  paymentRef      String?
  qrCode          String?       @unique
  pickedUpAt      DateTime?
  settledAt       DateTime?     // When merchant was paid

  // Ticket purchase metadata (stored until payment confirmed)
  ticketMetadata  Json?         // Stores {eventId, tickets: [{ticketTypeId, quantity, price}]}

  // Gift ticket fields
  isGift          Boolean       @default(false)
  recipientPhone  String?
  recipientName   String?
  giftMessage     String?

  // Cancellation support
  cancelledAt     DateTime?
  cancelledBy     String?       // 'user', 'admin', or 'system'
  cancellationReason String?
  refundStatus    RefundStatus?
  refundAmount    Float?
  refundedAt      DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  userId          String
  pickupLocation  PickupLocation? @relation(fields: [pickupLocationId], references: [id])
  pickupLocationId String?

  // Direct merchant relationship for shop orders
  merchant        Merchant?     @relation(fields: [merchantId], references: [id])
  merchantId      String?

  tickets         Ticket[]
  items           OrderItem[]
  payment         Payment?
  insurance       TicketInsurance?

  @@index([userId])
  @@index([status])
  @@index([merchantId])
  @@index([createdAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
  REFUNDED
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model OrderItem {
  id        String   @id @default(uuid())
  quantity  Int
  price     Float          // Unit price at time of purchase
  subtotal  Float         @default(0)  // quantity * price
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id])
  orderId   String
  shopItem  ShopItem @relation(fields: [shopItemId], references: [id])
  shopItemId String

  @@index([orderId])
  @@index([shopItemId])
  @@map("order_items")
}

// ============== PAYMENTS ==============

model Payment {
  id            String        @id @default(uuid())
  amount        Float
  currency      String        @default("ETB")
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  providerRef   String?
  providerData  Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order         Order         @relation(fields: [orderId], references: [id])
  orderId       String        @unique

  @@map("payments")
}

enum PaymentMethod {
  CHAPA
  TELEBIRR
  CBE_BIRR
  BANK_TRANSFER
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// ============== EVENT SESSIONS (Multi-Day/Multi-Session) ==============

model EventSession {
  id          String   @id @default(uuid())
  title       String   // "Day 1 - Opening Ceremony", "Morning Session"
  date        DateTime
  endDate     DateTime?
  venue       String?  // Override event venue if different
  capacity    Int?     // Override event capacity if limited
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String

  @@index([eventId])
  @@index([eventId, date])
  @@map("event_sessions")
}

// ============== EVENT MESSAGES (Organizer → Attendees) ==============

model EventMessage {
  id          String              @id @default(uuid())
  subject     String
  body        String
  channel     MessageChannel      @default(SMS)
  status      MessageStatus       @default(DRAFT)
  recipientCount Int              @default(0)
  sentCount   Int                 @default(0)
  failedCount Int                 @default(0)
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String
  sentBy      String?             // Organizer user ID

  @@index([eventId])
  @@index([eventId, status])
  @@map("event_messages")
}

enum MessageChannel {
  SMS
  WHATSAPP
  EMAIL
  PUSH
}

enum MessageStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

// ============== REFERRAL / AFFILIATE SYSTEM ==============

model Referral {
  id              String        @id @default(uuid())
  code            String        @unique    // e.g., "JOHN2026", auto-generated
  commissionRate  Float         @default(5) // Percentage commission for referrer
  clicks          Int           @default(0)
  conversions     Int           @default(0) // Tickets sold via this link
  totalEarnings   Float         @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  referrer        User          @relation("ReferrerUser", fields: [referrerId], references: [id])
  referrerId      String
  event           Event?        @relation(fields: [eventId], references: [id])
  eventId         String?       // null = global referral link

  @@unique([referrerId, eventId])
  @@index([code])
  @@index([referrerId])
  @@index([eventId])
  @@map("referrals")
}

// ============== FOLLOW ORGANIZERS ==============

model OrganizerFollow {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  organizerId String

  @@unique([userId, organizerId])
  @@index([userId])
  @@index([organizerId])
  @@map("organizer_follows")
}

// ============== PRESALE / EARLY ACCESS CODES ==============

model PresaleCode {
  id          String   @id @default(uuid())
  code        String   @unique
  maxUses     Int      @default(1)
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  validFrom   DateTime
  validUntil  DateTime
  createdAt   DateTime @default(now())

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String

  @@index([code])
  @@index([eventId])
  @@map("presale_codes")
}

// ============== TICKET RESALE MARKETPLACE ==============

model TicketResale {
  id            String        @id @default(uuid())
  askingPrice   Float         // Max 150% of original price
  originalPrice Float
  status        ResaleStatus  @default(LISTED)
  platformFee   Float         @default(0) // Calculated on sale
  listedAt      DateTime      @default(now())
  soldAt        DateTime?
  cancelledAt   DateTime?

  ticket        Ticket        @relation(fields: [ticketId], references: [id])
  ticketId      String        @unique
  sellerId      String
  buyerId       String?       // Set when purchased
  event         Event         @relation(fields: [eventId], references: [id])
  eventId       String

  @@index([eventId, status])
  @@index([sellerId])
  @@map("ticket_resales")
}

enum ResaleStatus {
  LISTED
  SOLD
  CANCELLED
  EXPIRED
}

// ============== EVENT RATINGS & SURVEYS ==============

model EventRating {
  id          String   @id @default(uuid())
  rating      Int      // 1-5 stars
  review      String?
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  userId      String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String

  @@unique([userId, eventId])
  @@index([eventId])
  @@map("event_ratings")
}

// ============== DONATIONS ==============

model Donation {
  id          String   @id @default(uuid())
  amount      Float
  currency    String   @default("ETB")
  message     String?
  isAnonymous Boolean  @default(false)
  paymentRef  String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  userId      String
  event       Event    @relation(fields: [eventId], references: [id])
  eventId     String

  @@index([eventId])
  @@index([userId])
  @@map("donations")
}

// ============== VENUE MANAGEMENT ==============

model Venue {
  id          String   @id @default(uuid())
  name        String
  address     String
  city        String   @default("Addis Ababa")
  latitude    Float?
  longitude   Float?
  capacity    Int?
  description String?
  imageUrl    String?
  gallery     Json?    // Array of image URLs
  amenities   Json?    // ["parking", "wifi", "accessible", "food_court"]
  contactPhone String?
  contactEmail String?
  website     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([city])
  @@map("venues")
}

// ============== LOYALTY / REWARDS PROGRAM ==============

model LoyaltyAccount {
  id            String   @id @default(uuid())
  points        Int      @default(0)
  lifetimePoints Int     @default(0)
  tier          LoyaltyTier @default(BRONZE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String   @unique

  transactions  LoyaltyTransaction[]

  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id          String              @id @default(uuid())
  type        LoyaltyTransactionType
  points      Int                 // Positive = earned, negative = redeemed
  description String
  reference   String?             // Order ID, event ID, etc.
  createdAt   DateTime            @default(now())

  account     LoyaltyAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId   String

  @@index([accountId, createdAt])
  @@map("loyalty_transactions")
}

enum LoyaltyTier {
  BRONZE      // 0-499 lifetime points
  SILVER      // 500-1999 lifetime points
  GOLD        // 2000-4999 lifetime points
  PLATINUM    // 5000+ lifetime points
}

enum LoyaltyTransactionType {
  PURCHASE_EARN   // Points earned from ticket/shop purchase
  REFERRAL_EARN   // Points earned from referral
  REVIEW_EARN     // Points earned from leaving a review
  CHECKIN_EARN    // Points earned from checking in
  REDEMPTION      // Points spent for discount
  EXPIRY          // Points expired
  BONUS           // Promotional bonus points
}

// ============== TICKET INSURANCE ==============

model TicketInsurance {
  id            String              @id @default(uuid())
  premium       Float               // Cost of insurance
  coverageAmount Float              // Max refund amount
  status        InsuranceStatus     @default(ACTIVE)
  claimedAt     DateTime?
  claimReason   String?
  refundedAmount Float?
  createdAt     DateTime            @default(now())

  order         Order               @relation(fields: [orderId], references: [id])
  orderId       String              @unique
  userId        String

  @@index([userId])
  @@map("ticket_insurance")
}

enum InsuranceStatus {
  ACTIVE        // Insurance purchased, not yet claimed
  CLAIMED       // Claim submitted
  REFUNDED      // Refund processed
  EXPIRED       // Event passed without claim
  VOID          // Insurance voided (e.g., ticket used)
}

// ============== CORPORATE / B2B INVOICING ==============

model CorporateAccount {
  id            String   @id @default(uuid())
  companyName   String
  tinNumber     String?  // Tax ID
  contactName   String
  contactEmail  String
  contactPhone  String
  billingAddress String?
  creditLimit   Float    @default(0)
  paymentTerms  Int      @default(30) // Net-30 days
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String   @unique
  invoices      Invoice[]

  @@map("corporate_accounts")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique // e.g., INV-2026-0001
  status        InvoiceStatus @default(DRAFT)
  subtotal      Float
  tax           Float         @default(0)
  total         Float
  dueDate       DateTime
  paidAt        DateTime?
  notes         String?
  items         Json          // Array of line items
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  account       CorporateAccount @relation(fields: [accountId], references: [id])
  accountId     String
  orderId       String?

  @@index([accountId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// ============== CUSTOM BRANDED EVENT PAGES ==============

model EventBranding {
  id              String   @id @default(uuid())
  primaryColor    String   @default("#00b894")
  secondaryColor  String   @default("#6c5ce7")
  backgroundColor String   @default("#0a0a0f")
  fontFamily      String?
  logoUrl         String?
  bannerUrl       String?
  customCss       String?  // Additional CSS overrides
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  eventId         String   @unique
  organizerId     String

  @@map("event_brandings")
}

// ============== PROMOTERS ==============

model Promoter {
  id              String   @id @default(uuid())
  stageName       String            // "DJ Abel", "Teddy Afro"
  bio             String?
  photo           String?
  category        PromoterCategory
  phone           String?
  email           String?
  socialLinks     Json?             // { instagram: "...", tiktok: "...", youtube: "..." }
  isAvailable     Boolean  @default(true)
  rating          Float    @default(0)
  totalEvents     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?    @relation(fields: [userId], references: [id])
  userId          String?  @unique

  assignments     EventPromoter[]

  @@index([category])
  @@index([isAvailable])
  @@map("promoters")
}

model EventPromoter {
  id          String              @id @default(uuid())
  role        String              @default("PERFORMER") // PERFORMER, DJ, MC, SPEAKER, HOST
  fee         Float?              // Agreed fee for the event
  status      PromoterAssignmentStatus @default(PENDING)
  notes       String?
  confirmedAt DateTime?
  createdAt   DateTime            @default(now())

  promoter    Promoter            @relation(fields: [promoterId], references: [id])
  promoterId  String
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String

  @@unique([promoterId, eventId])
  @@index([eventId])
  @@index([promoterId])
  @@map("event_promoters")
}

enum PromoterCategory {
  MUSICIAN
  DJ
  COMEDIAN
  SPEAKER
  MC
  DANCER
  BAND
  OTHER
}

enum PromoterAssignmentStatus {
  PENDING     // Invited, not yet confirmed
  CONFIRMED   // Accepted the event
  DECLINED    // Rejected the invitation
  CANCELLED   // Was confirmed but cancelled
}
